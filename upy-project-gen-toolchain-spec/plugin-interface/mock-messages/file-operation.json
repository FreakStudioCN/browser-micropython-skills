      "op_id": "fo_write_main",
      "op": "write",
      "path": "firmware/main.py",
      "content": "# 温湿度监测报警器\n# MicroPython 主程序\n\nimport machine\nimport time\nfrom drivers.ssd1306_driver import SSD1306\nfrom drivers.sht30_driver import SHT30\n\n# I2C 初始化\ni2c = machine.I2C(0, scl=machine.Pin(22), sda=machine.Pin(21))\n\n# 外设初始化\ndisplay = SSD1306(i2c, addr=0x3C)\nsensor = SHT30(i2c, addr=0x44)\nbuzzer = machine.Pin(23, machine.Pin.OUT)\n\n# 阈值设定\nTEMP_THRESHOLD = 30.0\nHUMID_THRESHOLD = 70.0\n\ndef read_and_display():\n    temp, hum = sensor.read()\n    display.clear()\n    display.text(f'T: {temp:.1f}C', 0, 0)\n    display.text(f'H: {hum:.1f}%', 0, 16)\n    display.show()\n    return temp, hum\n\ndef alarm_if_needed(temp, hum):\n    if temp > TEMP_THRESHOLD or hum > HUMID_THRESHOLD:\n        buzzer.on()\n        time.sleep(0.5)\n        buzzer.off()\n\n# 主循环\nwhile True:\n    t, h = read_and_display()\n    alarm_if_needed(t, h)\n    time.sleep(2)\n",
      "encoding": "utf-8"
    }
  },
